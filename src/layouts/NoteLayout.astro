---
import BaseLayout from "./BaseLayout.astro";

const { frontmatter } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title={`${frontmatter.title} | Lab Notes`} description={frontmatter.description}>
  <section class="mx-auto max-w-4xl px-5 py-12">
    <a href={`${base}notes/`} class="text-sm font-black text-accent">← Lab Notes</a>
    <p class="mt-8 text-sm font-black uppercase tracking-[0.18em] text-teal">Engineering Log</p>
    <h1 class="mt-3 text-4xl font-black leading-tight text-ink">{frontmatter.title}</h1>
    <p class="mt-4 text-lg leading-8 text-slate-700">{frontmatter.question}</p>
    {frontmatter.evidence && <p class="mt-5 rounded-md border border-line bg-white px-4 py-3 text-sm font-bold text-muted">Evidence: {frontmatter.evidence}</p>}
    <article class="prose-research mt-8 rounded-lg border border-line bg-white p-6 shadow-sm">
      <slot />
    </article>
  </section>
</BaseLayout>
