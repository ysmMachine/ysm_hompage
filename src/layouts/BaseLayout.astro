---
import Header from "../components/Header.astro";
import "../styles.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Yu Seungmin | Edge AI & Applied ML",
  description = "Research portfolio, lab notes, and evidence archive for lightweight AI systems and applied machine learning pipelines."
} = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={`${base}assets/favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <footer class="border-t border-line bg-white">
      <div class="mx-auto flex max-w-6xl flex-col gap-3 px-5 py-8 text-sm text-muted md:flex-row md:items-center md:justify-between">
        <p class="font-bold text-ink">Yu Seungmin · Edge AI & Applied ML Lab Notebook</p>
        <p>Research portfolio, learning log, and evidence archive.</p>
      </div>
    </footer>
  </body>
</html>
