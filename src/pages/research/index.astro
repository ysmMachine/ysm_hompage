---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ResearchCard from "../../components/ResearchCard.astro";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const research = (await getCollection("research")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Research | Yu Seungmin">
  <section class="mx-auto max-w-6xl px-5 py-12">
    <p class="text-sm font-black uppercase tracking-[0.18em] text-accent">Research</p>
    <h1 class="mt-3 text-4xl font-black text-ink">Research Case Studies</h1>
    <p class="mt-4 max-w-3xl leading-7 text-muted">논문을 단순 목록으로 두지 않고, 문제-방법-결과-역할이 보이는 case study로 정리했습니다.</p>
    <div class="mt-10 space-y-5">
      {research.map((item) => (
        <ResearchCard
          title={item.data.title}
          subtitle={item.data.description}
          summary={item.data.summary}
          href={`${base}research/${item.slug}/`}
          image={`${base}${item.data.image}`}
          metrics={item.data.title === "MicroForest" ? ["+34%p recall", "7.2x latency", "two orders smaller", "150 tasks"] : item.data.title === "MicroTree" ? ["8,800x smaller", "15,000x faster", "F1-score 0.80", "single-task"] : ["YOLOv8", "SegFormer", "RBL calculation", "impacted filtering"]}
          tags={item.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
