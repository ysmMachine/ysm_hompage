---
interface Props {
  title: string;
  question: string;
  summary: string;
  evidence?: string;
  href: string;
}

const { title, question, summary, evidence, href } = Astro.props;
---

<article class="rounded-lg border border-line bg-white p-5 shadow-sm">
  <p class="text-xs font-black uppercase tracking-[0.16em] text-teal">Question</p>
  <h3 class="mt-2 text-lg font-black text-ink">{title}</h3>
  <p class="mt-3 text-sm font-bold text-slate-700">{question}</p>
  <p class="mt-3 text-sm leading-6 text-muted">{summary}</p>
  {evidence && <p class="mt-4 rounded-md bg-paper px-3 py-2 text-xs font-bold text-slate-600">Evidence: {evidence}</p>}
  <a href={href} class="mt-4 inline-flex text-sm font-black text-accent">Open note -></a>
</article>
