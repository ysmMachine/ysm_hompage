---
interface Props {
  value: string;
  label: string;
  detail?: string;
}

const { value, label, detail } = Astro.props;
---

<div class="rounded-lg border border-line bg-white p-4 shadow-sm">
  <p class="text-2xl font-black text-ink">{value}</p>
  <p class="mt-1 text-sm font-bold text-slate-700">{label}</p>
  {detail && <p class="mt-2 text-xs leading-5 text-muted">{detail}</p>}
</div>
